# Railway Runtime
PORT=3000
TZ=Asia/Jakarta
SCHEDULER_ENABLED=true
COMPACT_MODE=true
RIWAYAT_MAX_RECORDS=500
SCHEDULER_RUNS_RETAIN_DAYS=14

# Firebase Admin SDK
# Opsi A (disarankan): tempel JSON service account penuh ke satu variable.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"..."}

# Opsi B: pakai field terpisah.
FIREBASE_PROJECT_ID=telurku-fa78c
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@telurku-fa78c.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\nREPLACE_ME\\n-----END PRIVATE KEY-----\\n"
FIREBASE_DATABASE_URL=https://telurku-fa78c-default-rtdb.asia-southeast1.firebasedatabase.app
